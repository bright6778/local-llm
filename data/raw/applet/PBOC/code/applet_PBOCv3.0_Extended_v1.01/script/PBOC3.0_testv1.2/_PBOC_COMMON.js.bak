//**********************************************//
//return a string,value is same character,length is the inputlength
//**********************************************//
function PaddingData(Data_c,inputlength)
{
	var data_out="";
	for(var i=1;i<=inputlength;i++)
	{
		data_out=Data_c+data_out;
	}
	return data_out;
}
  
//**********************************************//
//fDDA
//**********************************************//
function fDDA(fDDA_VN,ICC_PK_Modulus,ICC_PK_Exponent,fDDA_Data)
{
	print('\n*******************************************');
	print('* fDDA');
	print('*******************************************');
	var Hash_in;
	if (fDDA_VN=="01"){
		if(Value_DF61!="") {
			if ((CAPP_ID_DF60=="01") || (CAPP_ID_DF60=="02") || (CAPP_ID_DF60=="03")){
				CARD=CARD.substr(0,14)+Value_DF61;
			}
		}
	  Hash_in = Unpredictable_Number + Amount_Authorised + Transaction_Currency_Code + CARD;		
	}else if(fDDA_VN=="00"){
		Hash_in = Unpredictable_Number;
	}else{
		error("Unknown CVN");
	}
	
  var Recovered_DDA = calc_RSA(ICC_PK_Modulus, ICC_PK_Exponent,fDDA_Data);
  
	print('* Recovered fDDA data: ' + Recovered_DDA);
  print('*******************************************');
	
  if (Recovered_DDA!=""){
    if (Recovered_DDA.substr(0,2)!=RECOVERED_HEAD)	{
  	  error("Recovered Signed Data head error-fDDA");
    }
    if (Recovered_DDA.substr(2,2)!=signed_DATA_FORMAT){
    	error("Signed Data format error-fDDA");
    }
    if (Recovered_DDA.substr((Recovered_DDA.length - 2),2)!=DATA_TRAILER){
    	error("Recovered Signed Data tail error-fDDA");
    }
    
    var ICC_DYNAMIC_DATA_LENGTH = Recovered_DDA.substr(6, 2);
    if (ICC_DYNAMIC_DATA_LENGTH!="03"){
    	error("ICC Dynamic Data Length error-fDDA");
    }
    var ATC_in_fDDA=Recovered_DDA.substr(10, 4);
    
    var ICC_DYNAMIC_DATA_LENGTH_int = to_val(ICC_DYNAMIC_DATA_LENGTH) * 2;  
    var BB_length = ICC_PK_Modulus.length - ICC_DYNAMIC_DATA_LENGTH_int - 50;
    var BB_Recovered = Recovered_DDA.substr((8 + ICC_DYNAMIC_DATA_LENGTH_int),(ICC_PK_Modulus.length - 42 - 8 - ICC_DYNAMIC_DATA_LENGTH_int));
    if (BB_Recovered!=PaddingData("B",BB_length)){
    	error("'BB' padding error-fDDA");
    }
    var HASH_RESULT_DDA = Recovered_DDA.substr((ICC_PK_Modulus.length - 42),40);   
    var HASH_RESULT_DDA_T = messageDigest_SHA1(Recovered_DDA.substr(2,(ICC_PK_Modulus.length - 44)) + Hash_in);
    if (HASH_RESULT_DDA!=HASH_RESULT_DDA_T.toUpperCase()){
    	error("HASH Result error-fDDA");
    }
  }else{
	  error("Recovered fDDA data is empty-fDDA");
  }

}

