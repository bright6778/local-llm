{
	var GEN_AC_Response = send_GEN_AC_1(p1, AA_forVC + AO_forVC + TCO_forVC + TVR_forVC + TCC_forVC + TD_forVC + "FFFFFF"+ TT_forVC + "11223344");
	init_forVC();
	return GEN_AC_Response;
}

function send_GEN_AC2_forVC(p1)
