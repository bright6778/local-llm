}

function reset_VLP_Funds(VLP_Funds){
	print('\n* Case : reset VLP Funds');
		
	Terminal_Transaction_Qualifiers = "00000000";
	
	init(CT_PORT, CT_READER);
	print("***********************CAUTION!!!************************");
	print("Please remove active card and insert contact card");
	print("*********************************************************");
	pause();
	reset();
	
	reset();
	select_PBOC();
	assertSW('9000');
	send_GPO('831F015601000000000000015642616E6B436172645465737443656E7465722020');
	assertSW('9000');
	send_Verify('80', TEST_PLAIN_PIN);
	assertSW('9000');
	set_AA_forVC(AA_60);
	send_GEN_AC1_forVC(ARQC);
	assertSW('9000');
	send_ExternalAuth();
	assertSW('9000');
	set_AA_forVC(AA_60);
	send_GEN_AC2_forVC(TC);
	assertSW('9000');
							   	
	print("9F79 (VLP_Available_Funds) : " + VLP_Funds);

	//send_PutData("9F77", intToStr(VLP_Funds, 6));
	send_PutData("9F79", intToStr(VLP_Funds, 6)); 
	assertSW("9000");
	
	init(CL_PORT, CL_READER);
	print("***********************CAUTION!!!************************");
	print("Please remove active card and insert contactless card");
	print("*********************************************************");
	pause();
	reset();
}

