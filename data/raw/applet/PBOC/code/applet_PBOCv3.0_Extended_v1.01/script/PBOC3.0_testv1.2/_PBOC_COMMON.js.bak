function check_tags_in_response(response, tags)
{
	var data = lookup_BER_TLV(response, response.substring(0,2), RETURN_VALUE);
	
	print('\n*************************************************');
	print('* Check Tags in Response');
	print('*************************************************');
	
	for (var i = 0; i<tags.length; i++) {
		if (lookup_BER_TLV(data, tags[i], RETURN_VALUE) != '')
			print('* Checking - TAG ' + tags[i] + ' OK!!');
		else
			error('* Checking - TAG ' + tags[i] + ' NOT OK!!');
	}
}

function check_no_tags_in_response(response, tags)
{	
	var data = lookup_BER_TLV(response, response.substring(0,2), RETURN_VALUE);
	
	print('\n*************************************************');
	print('* Check No Tags in Response');
	print('*************************************************');
	
	for (var i = 0; i<tags.length; i++) {
		if (lookup_BER_TLV(data, tags[i], RETURN_VALUE) == '')
			print('* Checking - NO TAG ' + tags[i] + ' OK!!');
		else
			error('* Checking - NO TAG ' + tags[i] + ' NOT OK!!');
	}
}

